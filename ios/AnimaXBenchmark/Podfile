source 'https://cdn.cocoapods.org/'
project './AnimaXExample.xcodeproj'

def load_dependency_versions(path)
  versions = {}
  File.foreach(path) do |line|
    line = line.strip
    next if line.empty? || line.start_with?('#')

    key, value = line.split('=', 2)
    next if key.nil? || value.nil?
    versions[key.strip] = value.strip
  end
  versions
end

pod_path = File.expand_path('../../third_party/animax', __dir__)
dependency_versions = load_dependency_versions(File.expand_path(File.join(pod_path, 'versions.properties'), __dir__))

platform :ios, '13.0'

LYNX_VERSION = dependency_versions.fetch('LYNX_VERSION')
TEXTRA_VERSION = dependency_versions.fetch('TEXTRA_VERSION')
SKITY_VERSION = dependency_versions.fetch('SKITY_VERSION')

install!'cocoapods',:deterministic_uuids=>false,
                    :lock_pod_sources=>false,
                    :generate_multiple_pod_projects => true,
                    :incremental_installation=>true,
                    :warn_for_multiple_pod_sources => false

post_install do |installer|
  installer.pod_target_subprojects.flat_map { |p| p.targets }.each do |t|
    t.build_configurations.each do |c|
      c.build_settings['CODE_SIGNING_ALLOWED'] = "NO"
    end
  end
end

target 'AnimaXExample' do
  pod 'AnimaX', :path => pod_path, :subspecs => [
    'Core',
    'Framework',
    'RenderBackend/Skity',
    'Textra',
    'ThirdParty'
  ]

  pod 'skity', SKITY_VERSION
  pod 'LynxTextra', TEXTRA_VERSION
  pod 'LynxBase/Framework', LYNX_VERSION
  pod 'lottie-ios', '4.6.1'
end
