source 'https://cdn.cocoapods.org/'

project './AnimaXExample.xcodeproj'
platform :ios, '13.0'

ANIMAX_VERSION = '1.0.0'
LYNX_VERSION = '4.0.0-nightly.202606030642.55.ga9c771cc'
TEXTRA_VERSION = '0.1.5'
SKITY_VERSION = '1.1.0-alpha.0'
LOTTIE_IOS_VERSION = '4.6.1'

install! 'cocoapods',
         :deterministic_uuids => false,
         :lock_pod_sources => false,
         :generate_multiple_pod_projects => true,
         :incremental_installation => true,
         :warn_for_multiple_pod_sources => false

post_install do |installer|
  installer.pod_target_subprojects.flat_map(&:targets).each do |target|
    target.build_configurations.each do |config|
      config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
    end
  end
end

target 'AnimaXExample' do
  pod 'AnimaX', ANIMAX_VERSION, :subspecs => [
    'Core',
    'Framework',
    'RenderBackend/Skity',
    'Textra',
    'ThirdParty'
  ]

  pod 'skity', SKITY_VERSION
  pod 'LynxTextra', TEXTRA_VERSION
  pod 'LynxBase/Framework', LYNX_VERSION
  pod 'lottie-ios', LOTTIE_IOS_VERSION
end
